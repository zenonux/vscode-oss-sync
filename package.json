{
  "name": "vscode-oss-sync",
  "displayName": "OssSync",
  "description": "oss sync entension for vscode.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.62.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.vscode/oss-sync.json",
    "onCommand:vscode-oss-sync.initConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "menus": {
      "commandPalette": [
        {
          "command": "vscode-oss-sync.syncLocalToRemote",
          "when": "False"
        }
      ],
      "explorer/context": [
        {
          "command": "vscode-oss-sync.syncLocalToRemote",
          "when": "ossSync.enabled && resourcePath =~ /ossSyncAssets/",
          "group": "1_modification"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-oss-sync.initConfig",
        "title": "OssSync:Config"
      },
      {
        "command": "vscode-oss-sync.syncLocalToRemote",
        "title": "OssSync: Sync Local -> Remote"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "bugs": {
    "url": "https://github.com/zenonux/vscode-oss-sync/issues",
    "email": "zenonux@outlook.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zenonux/vscode-oss-sync.git"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.2",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^7.1.4",
    "@types/lodash": "^4.14.177",
    "@types/mocha": "^9.0.0",
    "@types/node": "14.x",
    "@types/vscode": "^1.62.0",
    "@typescript-eslint/eslint-plugin": "^4.31.1",
    "@typescript-eslint/parser": "^4.31.1",
    "@vscode/test-electron": "^1.6.2",
    "eslint": "^7.32.0",
    "glob": "^7.1.7",
    "mocha": "^9.1.1",
    "typescript": "^4.4.3"
  },
  "dependencies": {
    "ali-oss": "^6.16.0",
    "co": "^4.6.0",
    "fs-extra": "^10.0.0",
    "lodash": "^4.17.21"
  }
}
