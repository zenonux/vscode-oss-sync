{
  "name": "vscode-oss-sync",
  "displayName": "OssSync",
  "publisher": "zenonux",
  "description": "oss(ali-oss) sync extension for vscode.",
  "version": "0.2.2",
  "engines": {
    "vscode": "^1.62.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#404040",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:.vscode/oss-sync.json",
    "onCommand:vscode-oss-sync.config"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "menus": {
      "explorer/context": [
        {
          "command": "vscode-oss-sync.syncLocalToRemote",
          "when": "ossSync.enabled && !explorerResourceIsFolder && resourcePath =~ /ossSyncAssets/",
          "group": "1_modification"
        },
        {
          "command": "vscode-oss-sync.syncLocalToRemote",
          "when": "ossSync.enabled && explorerResourceIsFolder && resourcePath =~ /ossSyncAssets/",
          "group": "1_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "vscode-oss-sync.uploadFile",
          "when": "False"
        },
        {
          "command": "vscode-oss-sync.uploadFolder",
          "when": "False"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-oss-sync.config",
        "title": "OssSync:Config"
      },
      {
        "command": "vscode-oss-sync.uploadFile",
        "title": "OssSync:uploadFile(override)"
      },
      {
        "command": "vscode-oss-sync.uploadFolder",
        "title": "OssSync:uploadFolder"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p -w . --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "bugs": {
    "url": "https://github.com/zenonux/vscode-oss-sync/issues",
    "email": "zenonux@outlook.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zenonux/vscode-oss-sync.git"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.2",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^7.1.4",
    "@types/lodash": "^4.14.177",
    "@types/mocha": "^9.0.0",
    "@types/node": "14.x",
    "@types/vscode": "^1.62.0",
    "@typescript-eslint/eslint-plugin": "^4.31.1",
    "@typescript-eslint/parser": "^4.31.1",
    "@vscode/test-electron": "^1.6.2",
    "eslint": "^7.32.0",
    "glob": "^7.1.7",
    "mocha": "^9.1.1",
    "ts-loader": "^9.2.5",
    "typescript": "^4.4.3",
    "webpack": "^5.52.1",
    "webpack-cli": "^4.8.0"
  },
  "dependencies": {
    "ali-oss": "^6.16.0",
    "co": "^4.6.0",
    "fs-extra": "^10.0.0",
    "lodash": "^4.17.21",
    "qiniu": "^7.4.0"
  }
}
